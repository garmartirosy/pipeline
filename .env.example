# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── App database (Azure SQL Server) ──────────────────────────────────────────
ConnectionStrings__DefaultConnection=Server=tcp:<server>.database.windows.net,1433;Database=<dbname>;User ID=<user>;Password=<password>;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# ── PostgreSQL data source ────────────────────────────────────────────────────
POSTGRES_HOST=<host>.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=<database>
POSTGRES_USER=<username>
POSTGRES_PASSWORD=<password>
