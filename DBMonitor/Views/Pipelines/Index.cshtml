@{
    ViewData["Title"] = "Pipelines";
    Layout = "_Layout";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css"
      crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
    .arg-row            { display: flex; gap: .5rem; align-items: center; margin-bottom: .45rem; }
    .arg-row .arg-name  { width: 180px; font-family: monospace; font-size: .82rem; }
    .arg-row .arg-value { flex: 1;      font-family: monospace; font-size: .82rem; }
    .arg-row .arg-help  { font-size: .71rem; color: #888; white-space: nowrap;
                          overflow: hidden; text-overflow: ellipsis; max-width: 220px; }
    .arg-prefix         { font-family: monospace; font-size: .82rem; color: #888;
                          white-space: nowrap; user-select: none; }

    #output-content     { font-size: .78rem; max-height: 380px; overflow: auto;
                          background: #1e1e1e; color: #d4d4d4;
                          border-radius: 0 0 6px 6px; white-space: pre-wrap;
                          font-family: 'Cascadia Code', 'Fira Code', monospace; }

    #scriptModal .modal-content { background: #1e1e1e; border: 1px solid #3c3c3c; }
    #scriptModal .modal-header,
    #scriptModal .modal-footer  { background: #252526; border-color: #3c3c3c; }
    #scriptModal .modal-title   { font-family: monospace; font-size: .95rem; }
    #scriptModal .hljs          { padding: 1.2rem 1.4rem; font-size: .8rem; line-height: 1.6;
                                  overflow: auto; max-height: 68vh; border-radius: 0; }
    #scriptModal pre            { margin: 0; }
</style>

<h2 class="mb-4 h4">Pipelines</h2>

<!-- Step 1: URL -->
<div class="card mb-3">
    <div class="card-header fw-semibold">1 — Pipeline Script</div>
    <div class="card-body">
        <div class="d-flex gap-2">
            <input id="script-url" type="url" class="form-control font-monospace small"
                   placeholder="https://github.com/user/repo/blob/main/pipeline.py" />
            <button id="btn-fetch" class="btn btn-primary text-nowrap px-4">
                ↓ Load Pipeline
            </button>
        </div>
        <div id="fetch-spinner" class="mt-2 d-none small text-muted">
            <span class="spinner-border spinner-border-sm me-1"></span>Loading…
        </div>
        <div id="fetch-error" class="alert alert-danger mt-2 d-none small mb-0"></div>

        <div id="loaded-indicator" class="mt-3 d-none d-flex align-items-center gap-2">
            <span class="text-success fw-bold">✓</span>
            <span id="loaded-filename" class="fw-semibold font-monospace"></span>
            <button id="btn-open-preview" class="btn btn-sm btn-outline-secondary ms-1">
                &lt;/&gt; View Script
            </button>
        </div>
    </div>
</div>

<!-- Step 2: Arguments -->
<div id="section-args" class="card mb-3 d-none">
    <div class="card-header fw-semibold">2 — Arguments</div>
    <div class="card-body">
        <div id="args-list"></div>
        <button id="btn-add-arg" class="btn btn-sm btn-outline-secondary mt-1">
            + Add argument
        </button>
    </div>
</div>

<!-- Step 3: Dependencies -->
<div id="section-deps" class="card mb-3 d-none">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        <span>3 — Dependencies <span class="text-muted fw-normal">(optional)</span></span>
        <span id="deps-detected" class="badge bg-warning text-dark d-none">Missing packages detected</span>
    </div>
    <div class="card-body">
        <label for="deps-input" class="form-label small text-muted mb-1">
            pip packages to install before running — one per line or space-separated
        </label>
        <textarea id="deps-input" class="form-control form-control-sm font-monospace"
                  rows="2" placeholder="psycopg2-binary&#10;pandas numpy"></textarea>
        <div class="mt-2 d-flex align-items-center gap-2">
            <button id="btn-install" class="btn btn-sm btn-outline-primary">↓ Install</button>
            <span id="install-spinner" class="d-none small text-muted">
                <span class="spinner-border spinner-border-sm me-1"></span>Installing…
            </span>
        </div>
        <div id="install-result" class="mt-2 d-none">
            <pre id="install-output" class="mb-0 p-2 rounded small"
                 style="max-height:160px;overflow:auto;background:#1e1e1e;color:#d4d4d4;
                        font-family:'Cascadia Code','Fira Code',monospace;font-size:.75rem;
                        white-space:pre-wrap;"></pre>
        </div>
    </div>
</div>

<!-- Step 4: Run -->
<div id="section-run" class="mb-3 d-none">
    <button id="btn-run" class="btn btn-success px-4">▶ Run Pipeline</button>
    <span id="run-spinner" class="d-none ms-2 small text-muted">
        <span class="spinner-border spinner-border-sm me-1"></span>Running…
    </span>
</div>

<!-- Output -->
<div id="section-output" class="card d-none">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Output</span>
        <span id="output-badge" class="badge"></span>
    </div>
    <pre id="output-content" class="m-0 p-3"></pre>
</div>

<!-- Script preview modal -->
<div class="modal fade" id="scriptModal" tabindex="-1" aria-labelledby="modal-title-label">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header py-2">
                <div>
                    <h6 class="modal-title text-light mb-0" id="modal-title-label">
                        <span id="modal-filename"></span>
                    </h6>
                    <small class="text-secondary font-monospace" id="modal-raw-url"
                           style="font-size:.65rem"></small>
                </div>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <pre class="m-0"><code id="preview-code" class="language-python"></code></pre>
            </div>
            <div class="modal-footer py-2">
                <button id="btn-copy-script" class="btn btn-sm btn-outline-secondary">Copy</button>
                <button class="btn btn-sm btn-outline-light" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div hidden>@Html.AntiForgeryToken()</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/python.min.js"
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>

@section Scripts {
<script>
(function () {
    'use strict';

    const COPY_RESET_MS = 1500;

    const token          = document.querySelector('input[name="__RequestVerificationToken"]').value;
    const elUrl          = document.getElementById('script-url');
    const btnFetch       = document.getElementById('btn-fetch');
    const fetchSpinner   = document.getElementById('fetch-spinner');
    const fetchError     = document.getElementById('fetch-error');
    const loadedPanel    = document.getElementById('loaded-indicator');
    const loadedFilename = document.getElementById('loaded-filename');
    const btnOpenPreview = document.getElementById('btn-open-preview');
    const sectionArgs    = document.getElementById('section-args');
    const argsList       = document.getElementById('args-list');
    const btnAddArg      = document.getElementById('btn-add-arg');
    const sectionDeps     = document.getElementById('section-deps');
    const elDeps          = document.getElementById('deps-input');
    const depsDetected    = document.getElementById('deps-detected');
    const btnInstall      = document.getElementById('btn-install');
    const installSpinner  = document.getElementById('install-spinner');
    const installResult   = document.getElementById('install-result');
    const installOutput   = document.getElementById('install-output');
    const sectionRun     = document.getElementById('section-run');
    const btnRun         = document.getElementById('btn-run');
    const runSpinner     = document.getElementById('run-spinner');
    const sectionOutput  = document.getElementById('section-output');
    const outputContent  = document.getElementById('output-content');
    const outputBadge    = document.getElementById('output-badge');
    const modalFilename  = document.getElementById('modal-filename');
    const modalRawUrl    = document.getElementById('modal-raw-url');
    const previewCode    = document.getElementById('preview-code');
    const btnCopy        = document.getElementById('btn-copy-script');

    const scriptModal = new bootstrap.Modal(document.getElementById('scriptModal'));

    let state = { rawUrl: '', scriptContent: '' };

    // ── Load pipeline ─────────────────────────────────────────────────────────

    function loadPipeline() {
        const url = elUrl.value.trim();
        if (!url) return;

        btnFetch.disabled = true;
        fetchSpinner.classList.remove('d-none');
        fetchError.classList.add('d-none');
        loadedPanel.classList.add('d-none');
        sectionArgs.classList.add('d-none');
        sectionDeps.classList.add('d-none');
        sectionRun.classList.add('d-none');
        sectionOutput.classList.add('d-none');

        apiPost('@Url.Action("FetchScript", "Pipelines")', { url })
            .then(function onFetchSuccess(data) {
                if (data.error) { showFetchError(data.error); return; }

                state = { rawUrl: data.rawUrl, scriptContent: data.content };

                const parts = data.rawUrl.split('/');
                loadedFilename.textContent = parts[parts.length - 1];
                loadedPanel.classList.remove('d-none');

                argsList.innerHTML = '';
                (data.args || []).forEach(function (a) { addArgRow(a.name, '', a.required, a.help); });

                // Reset deps on new pipeline load
                elDeps.value = '';
                depsDetected.classList.add('d-none');
                sectionDeps.classList.remove('border-warning');

                sectionArgs.classList.remove('d-none');
                sectionDeps.classList.remove('d-none');
                sectionRun.classList.remove('d-none');
            })
            .catch(function onFetchError(e) { showFetchError(e.toString()); })
            .finally(function () {
                btnFetch.disabled = false;
                fetchSpinner.classList.add('d-none');
            });
    }

    function showFetchError(msg) {
        fetchError.textContent = msg;
        fetchError.classList.remove('d-none');
    }

    btnFetch.addEventListener('click', loadPipeline);
    elUrl.addEventListener('keydown', function (e) { if (e.key === 'Enter') loadPipeline(); });

    // ── Script preview modal ──────────────────────────────────────────────────

    btnOpenPreview.addEventListener('click', function openPreview() {
        const parts = state.rawUrl.split('/');
        modalFilename.textContent = parts[parts.length - 1];
        modalRawUrl.textContent   = state.rawUrl;

        previewCode.removeAttribute('data-highlighted');
        previewCode.textContent = state.scriptContent;
        hljs.highlightElement(previewCode);

        scriptModal.show();
    });

    btnCopy.addEventListener('click', function copyScript() {
        navigator.clipboard.writeText(state.scriptContent).then(function () {
            const original = btnCopy.textContent;
            btnCopy.textContent = 'Copied!';
            setTimeout(function () { btnCopy.textContent = original; }, COPY_RESET_MS);
        });
    });

    // ── Arguments ─────────────────────────────────────────────────────────────

    btnAddArg.addEventListener('click', function addCustomArg() {
        addArgRow('', '', false, '');
        const rows = argsList.querySelectorAll('.arg-row');
        rows[rows.length - 1]?.querySelector('.arg-name')?.focus();
    });

    function addArgRow(name, value, required, help) {
        const row = document.createElement('div');
        row.className = 'arg-row';

        const prefix = document.createElement('span');
        prefix.className = 'arg-prefix';
        prefix.textContent = '--';

        const nameInput = document.createElement('input');
        nameInput.type      = 'text';
        nameInput.className = 'form-control form-control-sm arg-name';
        nameInput.value     = name;
        nameInput.placeholder = 'arg_name';
        nameInput.readOnly    = !!name;

        const valInput = document.createElement('input');
        valInput.type       = 'text';
        valInput.className  = 'form-control form-control-sm arg-value';
        valInput.value      = value || '';
        valInput.placeholder = required ? 'required…' : 'value…';

        const removeBtn = document.createElement('button');
        removeBtn.className   = 'btn btn-sm btn-outline-danger';
        removeBtn.textContent = '×';
        removeBtn.addEventListener('click', function () { row.remove(); });

        row.append(prefix, nameInput, valInput);

        if (help) {
            const helpSpan = document.createElement('span');
            helpSpan.className   = 'arg-help d-none d-md-block';
            helpSpan.textContent = help;
            row.appendChild(helpSpan);
        }

        row.appendChild(removeBtn);
        argsList.appendChild(row);
    }

    // ── Run pipeline ──────────────────────────────────────────────────────────

    btnRun.addEventListener('click', function runPipeline() {
        if (!state.rawUrl) return;

        const args = Array.from(argsList.querySelectorAll('.arg-row'), function (row) {
            return {
                name:  row.querySelector('.arg-name').value.trim(),
                value: row.querySelector('.arg-value').value,
            };
        }).filter(function (a) { return a.name.length > 0; });

        btnRun.disabled = true;
        runSpinner.classList.remove('d-none');
        sectionOutput.classList.add('d-none');

        const packages = elDeps.value
            .split(/[\s,\n]+/)
            .map(function (p) { return p.trim(); })
            .filter(function (p) { return p.length > 0; });

        apiPost('@Url.Action("RunScript", "Pipelines")', { rawUrl: state.rawUrl, args, packages })
            .then(function onRunComplete(data) {
                sectionOutput.classList.remove('d-none');
                outputContent.textContent = data.output || '(no output)';
                outputBadge.textContent   = data.success ? 'Success' : 'Failed';
                outputBadge.className     = 'badge ' + (data.success ? 'bg-success' : 'bg-danger');
                sectionOutput.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

                if (!data.success) {
                    autoDetectMissingPackages(data.output || '');
                }
            })
            .catch(function onRunError(e) {
                sectionOutput.classList.remove('d-none');
                outputContent.textContent = e.toString();
                outputBadge.textContent   = 'Error';
                outputBadge.className     = 'badge bg-danger';
            })
            .finally(function () {
                btnRun.disabled = false;
                runSpinner.classList.add('d-none');
            });
    });

    // ── Install packages on demand ────────────────────────────────────────────

    btnInstall.addEventListener('click', function installPackages() {
        const packages = elDeps.value
            .split(/[\s,\n]+/)
            .map(function (p) { return p.trim(); })
            .filter(function (p) { return p.length > 0; });

        if (packages.length === 0) return;

        btnInstall.disabled = true;
        installSpinner.classList.remove('d-none');
        installResult.classList.add('d-none');

        apiPost('@Url.Action("InstallPackages", "Pipelines")', { packages })
            .then(function onInstallComplete(data) {
                installOutput.textContent = data.output || '(no output)';
                installOutput.style.borderLeft = data.success
                    ? '3px solid #4caf50'
                    : '3px solid #f44336';
                installResult.classList.remove('d-none');
                if (data.success) {
                    depsDetected.classList.add('d-none');
                    sectionDeps.classList.remove('border-warning');
                }
            })
            .catch(function onInstallError(e) {
                installOutput.textContent = e.toString();
                installOutput.style.borderLeft = '3px solid #f44336';
                installResult.classList.remove('d-none');
            })
            .finally(function () {
                btnInstall.disabled = false;
                installSpinner.classList.add('d-none');
            });
    });

    // ── Auto-detect missing pip packages from run output ─────────────────────

    function autoDetectMissingPackages(output) {
        const pattern = /No module named ['"]([^'"]+)['"]/g;
        const found   = new Set();
        let m;
        const binaryOnly = { 'psycopg2': 'psycopg2-binary', 'cv2': 'opencv-python-headless' };
        while ((m = pattern.exec(output)) !== null) {
            // Take only the top-level package name (e.g. "sklearn" from "sklearn.model_selection")
            const pkg = m[1].split('.')[0];
            found.add(binaryOnly[pkg] ?? pkg);
        }
        if (found.size === 0) return;

        const existing = new Set(
            elDeps.value.split(/[\s,\n]+/).map(function (p) { return p.trim(); }).filter(Boolean)
        );
        found.forEach(function (pkg) { existing.add(pkg); });
        elDeps.value = Array.from(existing).join('\n');

        depsDetected.classList.remove('d-none');
        sectionDeps.classList.add('border-warning');
        sectionDeps.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // ── Shared fetch helper ───────────────────────────────────────────────────

    function apiPost(url, body) {
        return fetch(url, {
            method:  'POST',
            headers: {
                'Content-Type':             'application/json',
                'RequestVerificationToken': token,
            },
            body: JSON.stringify(body),
        }).then(function parseJson(r) {
            if (!r.ok) throw new Error(`Server error: ${r.status} ${r.statusText}`);
            return r.json();
        });
    }
}());
</script>
}
