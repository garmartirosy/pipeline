@{
    ViewData["Title"] = "Random Insert";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 h4">Random Insert — <code>test_insert</code></h2>
</div>

<div class="card random-card">
    <div class="card-body text-center py-5">
        <p class="text-muted mb-4">
            Generates a random name and a number between 0 and 1000,
            then inserts a new row into <code>industrydb.public.test_insert</code>.
        </p>

        <button id="btn-insert" class="btn btn-primary btn-lg px-5">
            Insert Random Row
        </button>

        <div id="spinner" class="mt-3 d-none">
            <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                <span class="visually-hidden">Running…</span>
            </div>
            Running script…
        </div>

        <div id="result" class="mt-4 d-none" role="alert">
            <div id="result-icon" class="fs-1 mb-2" aria-hidden="true"></div>
            <div id="result-msg" class="font-monospace small"></div>
        </div>
    </div>
</div>

<div hidden>@Html.AntiForgeryToken()</div>

@section Scripts {
<script>
(function () {
    'use strict';

    const btn    = document.getElementById('btn-insert');
    const spinner = document.getElementById('spinner');
    const result  = document.getElementById('result');
    const icon    = document.getElementById('result-icon');
    const msg     = document.getElementById('result-msg');
    const token   = document.querySelector('input[name="__RequestVerificationToken"]').value;

    btn.addEventListener('click', function onInsertClick() {
        btn.disabled = true;
        spinner.classList.remove('d-none');
        result.classList.add('d-none');

        fetch('@Url.Action("Insert", "Random")', {
            method:  'POST',
            headers: {
                'Content-Type':             'application/json',
                'RequestVerificationToken': token,
            },
        })
        .then(function parseJson(r) {
            if (!r.ok) throw new Error(`Server error: ${r.status} ${r.statusText}`);
            return r.json();
        })
        .then(function showResult(data) {
            result.classList.remove('d-none');
            icon.textContent = data.success ? '✅' : '❌';
            result.className = 'mt-4 alert ' + (data.success ? 'alert-success' : 'alert-danger') + ' text-start';
            msg.textContent  = data.message || '(no output)';
        })
        .catch(function showError(err) {
            result.classList.remove('d-none');
            icon.textContent = '❌';
            result.className = 'mt-4 alert alert-danger text-start';
            msg.textContent  = err.toString();
        })
        .finally(function () {
            btn.disabled = false;
            spinner.classList.add('d-none');
        });
    });
}());
</script>
}
