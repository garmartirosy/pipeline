@model DBMonitor.Models.UserPreferences
@{
    ViewData["Title"] = "Settings";
}

<h2 class="mb-4">Settings</h2>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">
        @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">

    @* Preferences *@
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header fw-semibold">Preferences</div>
            <div class="card-body">
                <form asp-action="Save" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="DefaultPageSize" class="form-label fw-semibold">Default page size</label>
                        <input asp-for="DefaultPageSize" type="number" class="form-control" min="10" max="1000" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultQueryTimeout" class="form-label fw-semibold">Default query timeout (seconds)</label>
                        <input asp-for="DefaultQueryTimeout" type="number" class="form-control" min="1" max="300" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultMaxRows" class="form-label fw-semibold">Default max rows</label>
                        <input asp-for="DefaultMaxRows" type="number" class="form-control" min="10" max="100000" />
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="ConfirmDestructiveByDefault" class="form-check-input" type="checkbox" />
                        <label asp-for="ConfirmDestructiveByDefault" class="form-check-label">
                            Confirm destructive statements by default
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary">Save preferences</button>
                </form>
            </div>
        </div>
    </div>

    @* Privacy *@
    <div class="col-lg-6">
        <div class="card border-danger">
            <div class="card-header fw-semibold text-danger">Privacy & Data</div>
            <div class="card-body d-flex flex-column gap-3">

                <form asp-action="DeleteAuditLog" method="post"
                      onsubmit="return confirm('Clear your entire audit log? This cannot be undone.')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100">Clear audit log</button>
                    <div class="text-muted small mt-1">Deletes all your query history.</div>
                </form>

                <form asp-action="DeleteSavedQueries" method="post"
                      onsubmit="return confirm('Delete all saved queries? This cannot be undone.')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100">Delete saved queries</button>
                    <div class="text-muted small mt-1">Removes all your saved SQL snippets.</div>
                </form>

                <hr />

                <form asp-action="DeleteAccount" method="post"
                      onsubmit="return confirm('Delete your account and all data permanently? This cannot be undone.')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger w-100">Delete my account</button>
                    <div class="text-muted small mt-1">Removes all connections, queries, audit log, and your account.</div>
                </form>

            </div>
        </div>
    </div>

</div>

